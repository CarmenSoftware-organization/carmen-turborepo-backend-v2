# Prisma OpenSSL fix for Ubuntu
PRISMA_CLIENT_ENGINE_TYPE=library

# Application Name
APP_NAME=Micro-Business
NODE_ENV=development

## PORT

GATEWAY_SERVICE_HOST=localhost
GATEWAY_SERVICE_HTTP_PORT=4000
GATEWAY_SERVICE_HTTPS_PORT=4001

BUSINESS_SERVICE_HOST=localhost
BUSINESS_SERVICE_TCP_PORT=5020
BUSINESS_SERVICE_HTTP_PORT=6020

CLUSTER_SERVICE_HOST=localhost
CLUSTER_SERVICE_TCP_PORT=5014
CLUSTER_SERVICE_HTTP_PORT=6014

CRONJOB_SERVICE_HOST=localhost
CRONJOB_SERVICE_TCP_PORT=5012
CRONJOB_SERVICE_HTTP_PORT=6012

FILE_SERVICE_HOST=localhost
FILE_SERVICE_TCP_PORT=5007
FILE_SERVICE_HTTP_PORT=6007

KEYCLOAK_API_SERVICE_HOST=localhost
KEYCLOAK_API_SERVICE_TCP_PORT=5013
KEYCLOAK_API_SERVICE_HTTP_PORT=6013

NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_TCP_PORT=5006
NOTIFICATION_SERVICE_HTTP_PORT=6006

REPORT_SERVICE_HOST=localhost
REPORT_SERVICE_TCP_PORT=5015
REPORT_SERVICE_HTTP_PORT=6015
REPORT_SERVICE_GRPC_PORT=5015

REPORT_RENDER_HOST=localhost
REPORT_RENDER_TCP_PORT=8001

SYSTEM_SCHEMA_NAME=CARMEN_SYSTEM
SYSTEM_DATABASE_URL="postgresql://user:password@localhost:6432/postgres?pgbouncer=true&schema=${SYSTEM_SCHEMA_NAME}"
SYSTEM_DIRECT_URL="postgresql://user:password@localhost:5432/postgres?schema=${SYSTEM_SCHEMA_NAME}"

# JWT configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
JWT_INVITE_EXPIRES_IN=1d

# User invitation/registration
INVITATION_LIMIT_HOURS=24
REGISTER_BASE_URL=http://localhost:3000
RESET_PASSWORD_LIMIT_HOURS=24
RESET_PASSWORD_BASE_URL=http://localhost:3000

# SMTP (email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# OpenTelemetry Tracing
OTEL_TRACING_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://dev.blueledgers.com:4318
OTEL_SERVICE_NAME=micro-business

# Sentry
SENTRY_DSN=
