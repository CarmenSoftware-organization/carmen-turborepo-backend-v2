# Prisma OpenSSL fix for Ubuntu
PRISMA_CLIENT_ENGINE_TYPE=library
# micro-business service (consolidated)
BUSINESS_SERVICE_HOST=0.0.0.0
BUSINESS_SERVICE_PORT=5020
BUSINESS_SERVICE_HTTP_PORT=6020

# Database
SYSTEM_DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres?schema=CARMEN_SYSTEM"
SYSTEM_DIRECT_URL="postgresql://postgres:password@localhost:5432/postgres?schema=CARMEN_SYSTEM"

# JWT configuration
SUPABASE_JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
JWT_INVITE_EXPIRES_IN=1d

# User invitation/registration
INVITATION_LIMIT_HOURS=24
REGISTER_BASE_URL=http://localhost:3000
RESET_PASSWORD_LIMIT_HOURS=24
RESET_PASSWORD_BASE_URL=http://localhost:3000

# SMTP (email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Inter-service communication (external services)
KEYCLOAK_API_SERVICE_HOST=127.0.0.1
KEYCLOAK_API_SERVICE_PORT=5013
FILE_SERVICE_HOST=127.0.0.1
FILE_SERVICE_PORT=5007
REPORT_SERVICE_HOST=127.0.0.1
REPORT_SERVICE_PORT=5004
CRONJOB_SERVICE_HOST=127.0.0.1
CRONJOB_SERVICE_PORT=5012

# Logging (Loki)
LOKI_HOST=dev.blueledgers.com
LOKI_PORT=3998
LOKI_PROTOCOL=http
LOKI_USERNAME=
LOKI_PASSWORD=
APP_NAME=micro-business
NODE_ENV=development
LOG_LEVEL=info

# Sentry
SENTRY_DSN=
