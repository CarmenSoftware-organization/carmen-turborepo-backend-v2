# Prisma OpenSSL fix for Ubuntu
PRISMA_CLIENT_ENGINE_TYPE=library
# micro-keycloak-api service
KEYCLOAK_API_SERVICE_HOST=0.0.0.0
KEYCLOAK_API_SERVICE_PORT=5013
KEYCLOAK_API_SERVICE_HTTP_PORT=6013

# Keycloak Configuration
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=CARMEN_realm
KEYCLOAK_CLIENT_ID=account
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=carmen-admin
KEYCLOAK_ADMIN_PASSWORD=your-admin-password
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Logging (Loki)
LOKI_HOST=dev.blueledgers.com
LOKI_PORT=3998
LOKI_PROTOCOL=http
LOKI_USERNAME=
LOKI_PASSWORD=
APP_NAME=micro-keycloak-api
NODE_ENV=development
LOG_LEVEL=info
