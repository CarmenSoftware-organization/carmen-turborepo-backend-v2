# Prisma OpenSSL fix for Ubuntu
PRISMA_CLIENT_ENGINE_TYPE=library
# Service port number

## gateway service

GATEWAY_SERVICE_HOST=0.0.0.0
GATEWAY_SERVICE_PORT=4000
GATEWAY_SERVICE_HTTPS_PORT=4001

## micro-business (consolidated: auth, cluster, license, log, inventory, master, procurement, recipe)

BUSINESS_SERVICE_HOST=127.0.0.1
BUSINESS_SERVICE_PORT=5020
BUSINESS_SERVICE_HTTP_PORT=6020

# Legacy aliases pointing to micro-business
AUTH_SERVICE_HOST=127.0.0.1
AUTH_SERVICE_PORT=5020
AUTH_SERVICE_HTTP_PORT=6020

## micro-cluster (separate service)
CLUSTER_SERVICE_HOST=127.0.0.1
CLUSTER_SERVICE_PORT=5014
CLUSTER_SERVICE_HTTP_PORT=6014

LICENSE_SERVICE_HOST=127.0.0.1
LICENSE_SERVICE_PORT=5020
LICENSE_SERVICE_HTTP_PORT=6020

INVENTORY_SERVICE_HOST=127.0.0.1
INVENTORY_SERVICE_PORT=5020
INVENTORY_SERVICE_HTTP_PORT=6020

PROCUREMENT_SERVICE_HOST=127.0.0.1
PROCUREMENT_SERVICE_PORT=5020
PROCUREMENT_SERVICE_HTTP_PORT=6020

RECIPE_SERVICE_HOST=127.0.0.1
RECIPE_SERVICE_PORT=5020
RECIPE_SERVICE_HTTP_PORT=6020

MASTER_SERVICE_HOST=127.0.0.1
MASTER_SERVICE_PORT=5020
MASTER_SERVICE_HTTP_PORT=6020

LOG_SERVICE_HOST=127.0.0.1
LOG_SERVICE_PORT=5020
LOG_SERVICE_HTTP_PORT=6020

## microservice reports (separate service)

REPORT_SERVICE_HOST=127.0.0.1
REPORT_SERVICE_PORT=5004
REPORT_SERVICE_HTTP_PORT=6004

## microservice notifications (separate service)

NOTIFICATION_SERVICE_HOST=127.0.0.1
NOTIFICATION_SERVICE_PORT=5006
NOTIFICATION_SERVICE_HTTP_PORT=6006

## microservice files (separate service)

FILE_SERVICE_HOST=127.0.0.1
FILE_SERVICE_PORT=5007
FILE_SERVICE_HTTP_PORT=6007

## microservice cronjob (separate service)

CRONJOB_SERVICE_HOST=127.0.0.1
CRONJOB_SERVICE_PORT=5012
CRONJOB_SERVICE_HTTP_PORT=6012

## microservice keycloak-api (separate service)

KEYCLOAK_API_SERVICE_HOST=127.0.0.1
KEYCLOAK_API_SERVICE_PORT=5013
KEYCLOAK_API_SERVICE_HTTP_PORT=6013

LOKI_HOST=dev.blueledgers.com
LOKI_PORT=3998
LOKI_PROTOCOL=http
LOKI_USERNAME=
LOKI_PASSWORD=
APP_NAME=backend-gateway
NODE_ENV=development

IS_ACTIVE_NOTIFICATION=true

## supabase
SUPABASE_JWT_SECRET=your-jwt-secret

# Reset password configuration
RESET_PASSWORD_BASE_URL=https://yourapp.com/reset-password
RESET_PASSWORD_LIMIT_HOURS=1

# SMTP configuration for email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourapp.com
