meta {
  name: 13 - Confirm PR
  type: http
  seq: 13
}

post {
  url: {{host}}/api/{{bu_code}}/purchase-order/confirm-pr
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "workflow_id": "<workflow_uuid>",
    "pr_ids": [
      "<pr_uuid_1>",
      "<pr_uuid_2>"
    ]
  }
}
