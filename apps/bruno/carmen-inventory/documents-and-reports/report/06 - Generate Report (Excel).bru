meta {
  name: 06 - Generate Report (Excel)
  type: http
  seq: 6
}

docs {
  ## Generate Report (Excel)
  สร้างรายงานในรูปแบบ Excel

  Generate a report in Excel format.


  ### Sample Body
  ```json
  {
    "report_type": "inventory_summary",
    "format": "excel",
    "filters": {},
    "options": {}
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

post {
  url: {{host}}/api/{{bu_code}}/report/generate
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "report_type": "inventory_summary",
    "format": "excel",
    "filters": {},
    "options": {}
  }
}
