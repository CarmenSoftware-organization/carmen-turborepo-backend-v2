meta {
  name: Generate report
  type: http
  seq: 7
}

post {
  url: {{host}}/api/{{bu_code}}/report/generate
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
  Content-Type: application/json
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "report_type": "",
    "format": "",
    "filters": "",
    "options": "",
    "template_id": ""
  }
}

docs {
  ## Generate Report (CSV)
  สร้างรายงานในรูปแบบ CSV

  Generate a report in CSV format.


  ### Sample Body
  ```json
  {
    "report_type": "inventory_summary",
    "format": "csv",
    "filters": {},
    "options": {}
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}
