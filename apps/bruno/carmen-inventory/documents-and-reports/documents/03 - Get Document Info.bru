meta {
  name: 03 - Get Document Info
  type: http
  seq: 3
}

docs {
  ## Get Document Info
  ดึงข้อมูลเมตาของเอกสารโดยไม่ดาวน์โหลดเนื้อหา

  Retrieve document metadata without downloading the file content.
}

get {
  url: {{host}}/api/{{bu_code}}/documents/:filetoken/info
  body: none
  auth: bearer
}

params:path {
  filetoken: {{filetoken}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
