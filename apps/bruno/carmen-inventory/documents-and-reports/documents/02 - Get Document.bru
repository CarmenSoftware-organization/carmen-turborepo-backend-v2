meta {
  name: 02 - Get Document
  type: http
  seq: 2
}

docs {
  ## Get Document
  ดึงข้อมูลเอกสารรายการเดียวตาม file token

  Download a specific document by its file token.
}

get {
  url: {{host}}/api/{{bu_code}}/documents/:filetoken
  body: none
  auth: bearer
}

params:path {
  filetoken: {{filetoken}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
