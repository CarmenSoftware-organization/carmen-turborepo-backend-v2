}

docs {
  ## List Notifications
  แสดงรายการการแจ้งเตือนทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieve all notifications with pagination and search support.
}

get {
  url: {{host}}/api/notifications
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
