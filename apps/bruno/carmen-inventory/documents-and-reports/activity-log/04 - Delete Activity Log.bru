meta {
  name: 04 - Delete Activity Log
  type: http
  seq: 4
}

docs {
  ## Delete Activity Log
  ลบบันทึกกิจกรรมตาม ID

  Delete an activity log entry by its ID.
}

delete {
  url: {{host}}/api/{{bu_code}}/activity-log/:id
  body: none
  auth: bearer
}

params:path {
  id: {{activity_log_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
