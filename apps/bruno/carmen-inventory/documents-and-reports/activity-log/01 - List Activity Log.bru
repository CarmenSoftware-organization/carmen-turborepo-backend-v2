meta {
  name: 01 - List Activity Log
  type: http
  seq: 1
}

docs {
  ## List Activity Log
  แสดงรายการบันทึกกิจกรรมทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieve all activity logs with pagination and search support.
}

get {
  url: {{host}}/api/{{bu_code}}/activity-log
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
