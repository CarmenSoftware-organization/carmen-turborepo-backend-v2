meta {
  name: Find all by product item group id product-item-group-comment
  type: http
  seq: 1
}

get {
  url: {{host}}/api/{{bu_code}}/product-item-group/:product_item_group_id/comments
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

query {
  ~version: 
}

docs {
  ## List Product Item Group Comments
  แสดงความคิดเห็นทั้งหมดของกลุ่มสินค้า

  Retrieves all comments for a product-item-group.

  ### Path Parameters
  - `product_item_group_id` — Product Item Group ID


  ### Sample Response
  ```json
  {
    "data": [
      {
        "id": "uuid",
        "message": "comment text"
      }
    ],
    "paginate": {
      "total": 100,
      "page": 1,
      "perpage": 10,
      "pages": 10
    },
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

params:path {
  product_item_group_id: {{test_id}}
}
