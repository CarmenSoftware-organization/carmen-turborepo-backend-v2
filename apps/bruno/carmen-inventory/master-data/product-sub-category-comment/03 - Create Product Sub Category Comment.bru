meta {
  name: 03 - Create Product Sub Category Comment
  type: http
  seq: 3
}

docs {
  ## Create Product Sub Category Comment
  สร้างความคิดเห็นใหม่สำหรับหมวดหมู่ย่อยสินค้า

  Posts a new comment on a product-sub-category.

  ### Sample Body
  ```json
  {
    "product_sub_category_id": "{{test_id}}",
    "message": ""
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 201,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

post {
  url: {{host}}/api/{{bu_code}}/product-sub-category-comment
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "product_sub_category_id": "{{test_id}}",
    "message": ""
  }
}
