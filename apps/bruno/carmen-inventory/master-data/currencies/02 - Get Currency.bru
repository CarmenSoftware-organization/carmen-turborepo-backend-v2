meta {
  name: By id currencies
  type: http
  seq: 2
}

get {
  url: {{host}}/api/{{bu_code}}/currencies/:id
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

query {
  ~version: 
}

docs {
  ## Get Currency
  ดึงข้อมูลสกุลเงินรายการเดียวตาม ID

  Retrieves the details of a specific currency including its code, symbol, and exchange rate configuration.

  ### Path Parameters
  - `id` -- Currency ID (UUID) / รหัสสกุลเงิน


  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid",
      "code": "THB",
      "name": "Thai Baht",
      "symbol": "฿",
      "exchange_rate": 1,
      "is_active": true
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

params:path {
  id: {{currency_id}}
}
