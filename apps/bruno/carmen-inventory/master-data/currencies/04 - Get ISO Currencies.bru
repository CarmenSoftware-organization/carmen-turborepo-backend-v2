meta {
  name: 04 - Get ISO Currencies
  type: http
  seq: 4
}

docs {
  ## Get ISO Currencies
  ดึงรายการสกุลเงินมาตรฐาน ISO 4217 ทั้งหมด

  Lists all ISO 4217 standard currencies available in the system for currency configuration.
}

get {
  url: {{host}}/api/iso
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
