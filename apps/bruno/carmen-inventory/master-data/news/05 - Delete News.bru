meta {
  name: 05 - Delete News
  type: http
  seq: 5
}

docs {
  ## Delete News
  ลบข่าวสารตาม ID

  Delete a news article by its ID.
}

delete {
  url: {{host}}/api/news/:id
  body: none
  auth: bearer
}

params:path {
  id: {{news_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
