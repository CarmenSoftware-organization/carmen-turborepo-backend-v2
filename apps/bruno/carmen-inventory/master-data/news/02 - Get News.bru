meta {
  name: 02 - Get News
  type: http
  seq: 2
}

docs {
  ## Get News
  ดึงข้อมูลข่าวสารรายการเดียวตาม ID

  Retrieve a single news article by its ID.
}

get {
  url: {{host}}/api/news/:id
  body: none
  auth: bearer
}

params:path {
  id: {{news_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
