meta {
  name: 01 - Get Product Locations
  type: http
  seq: 1
}

docs {
  ## Get Product Locations
  ดึงรายการสินค้าทั้งหมดตามรหัสสถานที่

  Retrieves all products assigned to a specific storage location or warehouse.

  ### Path Parameters
  - `id` — Location UUID (รหัสสถานที่)
}

get {
  url: {{host}}/api/{{bu_code}}/products/locations/:id
  body: none
  auth: bearer
}

params:path {
  id: {{product_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
