meta {
  name: 01 - List Department
  type: http
  seq: 1
}

docs {
  ## List Departments
  แสดงรายการแผนกทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all departments in the business unit with pagination and search support.
}

get {
  url: {{host}}/api/{{bu_code}}/department
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
