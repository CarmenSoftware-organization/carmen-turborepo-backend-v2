meta {
  name: 03 - Create Vendor Business Type Comment
  type: http
  seq: 3
}

docs {
  ## Create Vendor Business Type Comment
  สร้างความคิดเห็นใหม่สำหรับประเภทธุรกิจผู้ขาย

  Posts a new comment on a vendor-business-type.

  ### Sample Body
  ```json
  {
    "vendor_business_type_id": "{{test_id}}",
    "message": ""
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 201,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

post {
  url: {{host}}/api/{{bu_code}}/vendor-business-type-comment
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "vendor_business_type_id": "{{test_id}}",
    "message": ""
  }
}
