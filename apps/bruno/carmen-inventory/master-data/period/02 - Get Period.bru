meta {
  name: 02 - Get Period
  type: http
  seq: 2
}

docs {
  ## Get Period
  ดึงข้อมูลรอบบัญชีรายการเดียวตาม ID

  Retrieve a single fiscal/accounting period by its ID.
}

get {
  url: {{host}}/api/{{bu_code}}/period/:id
  body: none
  auth: bearer
}

params:path {
  id: {{period_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
