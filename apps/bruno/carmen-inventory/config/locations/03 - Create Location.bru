docs {
  ## Create Location
  สร้างสถานที่/คลังสินค้าใหม่

  Creates a new location/warehouse in the business unit.
}

post {
  url: {{host}}/api/config/{{bu_code}}/locations
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "code": "",
    "is_active": true
  }
}
