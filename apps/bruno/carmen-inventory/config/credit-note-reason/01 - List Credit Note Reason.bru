meta {
  name: 01 - List Credit Note Reason
  type: http
  seq: 1
}

docs {
  ## List Credit Note Reasons
  แสดงรายการเหตุผลใบลดหนี้ทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Returns all configurable reasons for issuing vendor credit notes with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/credit-note-reason
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
