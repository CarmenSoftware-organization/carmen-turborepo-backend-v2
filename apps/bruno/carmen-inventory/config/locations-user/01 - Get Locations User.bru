meta {
  name: 01 - Get Locations User
  type: http
  seq: 1
}

docs {
  ## Get Locations User
  ดึงข้อมูลสถานที่ทั้งหมดที่ผู้ใช้สามารถเข้าถึงได้ตาม User ID

  Retrieves all locations accessible to a specific user by their user ID.
}

get {
  url: {{host}}/api/config/{{bu_code}}/locations/user/:userId
  body: none
  auth: bearer
}

params:path {
  userId: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
