meta {
  name: 03 - Create Vendor
  type: http
  seq: 3
}

docs {
  ## Create Vendor
  สร้างผู้ขายใหม่

  Creates a new vendor/supplier in the business unit.
}

post {
  url: {{host}}/api/config/{{bu_code}}/vendors
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

