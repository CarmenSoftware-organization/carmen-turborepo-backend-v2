meta {
  name: 01 - List Vendor
  type: http
  seq: 1
}

docs {
  ## List Vendors
  แสดงรายการผู้ขายทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all vendors/suppliers configured in the business unit with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/vendors
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
