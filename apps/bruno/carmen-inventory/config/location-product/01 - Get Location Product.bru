meta {
  name: 01 - Get Location Product
  type: http
  seq: 1
}

docs {
  ## Get Location Product
  ดึงข้อมูลสถานที่ตามสินค้าโดยใช้รหัสสถานที่ แสดงสินค้าทั้งหมดที่ผูกกับสถานที่

  Retrieves all product-location mappings for a specific location, including product details and quantity settings.

  ### Path Parameters
  - `locationId` — Location UUID (รหัสสถานที่)
}

get {
  url: {{host}}/api/config/{{bu_code}}/location-product/:locationId
  body: none
  auth: bearer
}

params:path {
  locationId: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
