meta {
  name: 01 - List Product Category
  type: http
  seq: 1
}

docs {
  ## List Product Categories
  แสดงรายการหมวดหมู่สินค้าทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Returns all product categories configured for the business unit.
}

get {
  url: {{host}}/api/config/{{bu_code}}/products/category
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
