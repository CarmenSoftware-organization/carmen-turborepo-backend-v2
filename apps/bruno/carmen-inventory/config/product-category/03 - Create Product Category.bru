meta {
  name: 03 - Create Product Category
  type: http
  seq: 3
}

docs {
  ## Create Product Category
  สร้างหมวดหมู่สินค้าใหม่

  Defines a new top-level product category for classifying items in the master catalog.
}

post {
  url: {{host}}/api/config/{{bu_code}}/products/category
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "code": "",
    "is_active": true
  }
}
