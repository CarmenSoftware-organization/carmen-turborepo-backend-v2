docs {
  ## Get Product Category
  ดึงข้อมูลหมวดหมู่สินค้ารายการเดียวตาม ID

  Retrieves a specific product category by its ID.

  ### Path Parameters
  - `id` — Product Category UUID (รหัสหมวดหมู่สินค้า)
}

get {
  url: {{host}}/api/config/{{bu_code}}/products/category/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
