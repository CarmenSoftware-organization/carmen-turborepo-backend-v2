meta {
  name: 01 - List Department User
  type: http
  seq: 1
}

docs {
  ## List Department Users
  แสดงรายการผู้ใช้ประจำแผนกทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all department-user assignments with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/department-user
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
