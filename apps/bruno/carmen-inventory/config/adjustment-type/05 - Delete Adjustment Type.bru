meta {
  name: 05 - Delete Adjustment Type
  type: http
  seq: 5
}

docs {
  ## Delete Adjustment Type
  ลบประเภทการปรับปรุงตาม ID

  Deletes an adjustment type category by its unique identifier.
}

delete {
  url: {{host}}/api/config/{{bu_code}}/adjustment-type/:id
  body: none
  auth: bearer
}

params:path {
  id: {{adjustment_type_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
