meta {
  name: 01 - List Adjustment Type
  type: http
  seq: 1
}

docs {
  ## List Adjustment Types
  แสดงรายการประเภทการปรับปรุงทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all adjustment type categories with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/adjustment-type
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
