meta {
  name: 01 - List Price List
  type: http
  seq: 1
}

docs {
  ## List Price Lists (Config)
  แสดงรายการราคาทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Returns all vendor price lists configured for the business unit with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/price-list
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
