docs {
  ## Create Tax Profile
  สร้างโปรไฟล์ภาษีใหม่

  Creates a new tax rate configuration for use in procurement tax calculations.
}

post {
  url: {{host}}/api/config/{{bu_code}}/tax-profile
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "code": "",
    "is_active": true
  }
}
