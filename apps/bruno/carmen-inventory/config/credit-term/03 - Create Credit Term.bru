docs {
  ## Create Credit Term
  สร้างเงื่อนไขการชำระเงินใหม่

  Creates a new payment term definition (e.g., Net 30, Net 60, COD) for vendor agreements.
}

post {
  url: {{host}}/api/config/{{bu_code}}/credit-term
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "code": "",
    "is_active": true
  }
}
