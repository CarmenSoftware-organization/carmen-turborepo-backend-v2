docs {
  ## Get Credit Term
  ดึงข้อมูลเงื่อนไขการชำระเงินรายการเดียวตาม ID

  Retrieves a specific payment term definition by its unique identifier.

  ### Path Parameters
  - `id` -- Credit term ID (UUID) / รหัสเงื่อนไขการชำระเงิน
}

get {
  url: {{host}}/api/config/{{bu_code}}/credit-term/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
