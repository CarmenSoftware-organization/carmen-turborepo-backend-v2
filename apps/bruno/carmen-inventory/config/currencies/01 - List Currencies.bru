meta {
  name: 01 - List Currencies
  type: http
  seq: 1
}

docs {
  ## List Currencies
  แสดงรายการสกุลเงินทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Returns all currencies configured for the business unit with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/currencies
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
