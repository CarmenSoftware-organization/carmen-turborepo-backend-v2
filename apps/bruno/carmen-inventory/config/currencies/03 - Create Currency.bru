}

docs {
  ## Create Currency
  สร้างสกุลเงินใหม่ในระบบ

  Creates a new currency configuration for use in multi-currency procurement.
}

post {
  url: {{host}}/api/config/{{bu_code}}/currencies
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "code": "",
    "is_active": true
  }
}
