meta {
  name: 06 - Delete Currency
  type: http
  seq: 6
}

docs {
  ## Delete Currency
  ลบสกุลเงินตาม ID

  Removes a currency from active use by its unique identifier.

  ### Path Parameters
  - `id` -- Currency ID (UUID) / รหัสสกุลเงิน


  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

delete {
  url: {{host}}/api/config/{{bu_code}}/currencies/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
