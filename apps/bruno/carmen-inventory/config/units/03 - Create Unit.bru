docs {
  ## Create Unit
  สร้างหน่วยนับใหม่

  Creates a new unit of measurement in the business unit.
}

post {
  url: {{host}}/api/config/{{bu_code}}/units
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "code": "",
    "is_active": true
  }
}
