docs {
  ## Get Unit
  ดึงข้อมูลหน่วยนับรายการเดียวตาม ID

  Retrieves a single unit of measurement by its unique identifier.
}

get {
  url: {{host}}/api/config/{{bu_code}}/units/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
