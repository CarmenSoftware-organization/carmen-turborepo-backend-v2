meta {
  name: 01 - List Unit
  type: http
  seq: 1
}

docs {
  ## List Units
  แสดงรายการหน่วยนับทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all units of measurement configured in the business unit with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/units
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
