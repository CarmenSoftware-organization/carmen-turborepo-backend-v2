meta {
  name: 05 - Delete Workflow
  type: http
  seq: 5
}

docs {
  ## Delete Workflow
  ลบขั้นตอนการทำงานออกจากการใช้งาน เอกสารที่กำลังดำเนินการไม่ได้รับผลกระทบ

  Removes an approval workflow template from active use. Documents currently in progress are not affected.
}

delete {
  url: {{host}}/api/config/{{bu_code}}/workflows/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
