meta {
  name: 02 - Get Cronjob
  type: http
  seq: 2
}

docs {
  ## Get Cronjob by ID
  ดึงข้อมูลงานตั้งเวลาเดียวตาม ID รวมถึงตารางเวลา สถานะ และข้อมูลการรันล่าสุด

  Retrieves the configuration details of a specific scheduled task, including its cron schedule, execution status, and last run information.
}

get {
  url: {{host}}/api/config/cronjobs/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
