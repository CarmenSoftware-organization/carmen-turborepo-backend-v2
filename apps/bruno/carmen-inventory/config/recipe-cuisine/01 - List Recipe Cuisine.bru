meta {
  name: 01 - List Recipe Cuisine
  type: http
  seq: 1
}

docs {
  ## List Recipe Cuisines
  ดึงรายการประเภทอาหารทั้งหมดสำหรับการจัดหมวดหมู่สูตรอาหารและการวางแผนเมนู

  Returns all cuisine types configured for recipe classification and menu planning.
}

get {
  url: {{host}}/api/config/{{bu_code}}/recipe-cuisine
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
