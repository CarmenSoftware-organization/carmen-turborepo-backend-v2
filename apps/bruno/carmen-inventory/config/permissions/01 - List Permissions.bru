meta {
  name: 01 - List Permissions
  type: http
  seq: 1
}

docs {
  ## List Permissions
  แสดงรายการสิทธิ์การใช้งานทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all permission definitions with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/permissions
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
