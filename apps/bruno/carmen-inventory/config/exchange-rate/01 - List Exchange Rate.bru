meta {
  name: 01 - List Exchange Rate
  type: http
  seq: 1
}

docs {
  ## List Exchange Rates
  แสดงรายการอัตราแลกเปลี่ยนทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Returns all exchange rates configured for the business unit with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/exchange-rate
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
