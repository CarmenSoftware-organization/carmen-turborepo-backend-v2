docs {
  ## Get Exchange Rate
  ดึงข้อมูลอัตราแลกเปลี่ยนรายการเดียวตาม ID

  Retrieves a single exchange rate record by its unique identifier.

  ### Path Parameters
  - `id` -- Exchange rate ID (UUID) / รหัสอัตราแลกเปลี่ยน
}

get {
  url: {{host}}/api/config/{{bu_code}}/exchange-rate/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
