meta {
  name: 01 - List Extra Cost Type
  type: http
  seq: 1
}

docs {
  ## List Extra Cost Types
  แสดงรายการประเภทค่าใช้จ่ายเพิ่มเติมทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Returns all extra cost type categories configured for procurement with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/extra-cost-type
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
