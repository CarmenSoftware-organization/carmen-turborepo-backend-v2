docs {
  ## Get Application Role
  ดึงข้อมูลบทบาทในระบบรายการเดียวตาม ID

  Retrieves a single application role by its unique identifier.
}

get {
  url: {{host}}/api/config/{{bu_code}}/application-roles/:id
  body: none
  auth: bearer
}

params:path {
  id: 
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
