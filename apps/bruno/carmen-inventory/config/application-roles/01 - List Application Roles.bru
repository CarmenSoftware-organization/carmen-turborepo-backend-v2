meta {
  name: 01 - List Application Roles
  type: http
  seq: 1
}

docs {
  ## List Application Roles
  แสดงรายการบทบาทในระบบทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all application roles with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/application-roles
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
