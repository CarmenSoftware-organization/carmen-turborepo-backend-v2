docs {
  ## Create Application Role
  สร้างบทบาทในระบบใหม่

  Creates a new application role for access control.
}

post {
  url: {{host}}/api/config/{{bu_code}}/application-roles
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "code": "",
    "is_active": true
  }
}
