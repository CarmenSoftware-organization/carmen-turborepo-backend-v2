meta {
  name: 01 - List Departments
  type: http
  seq: 1
}

docs {
  ## List Departments
  แสดงรายการแผนกทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all departments configured in the business unit with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/departments
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
