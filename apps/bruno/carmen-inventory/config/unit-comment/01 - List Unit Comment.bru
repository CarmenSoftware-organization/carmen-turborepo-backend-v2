meta {
  name: 01 - List Unit Comment
  type: http
  seq: 1
}

docs {
  ## List Unit Comments
  แสดงรายการหมายเหตุหน่วยนับทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieves all unit comment templates with pagination and search support.
}

get {
  url: {{host}}/api/config/{{bu_code}}/unit-comment
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
