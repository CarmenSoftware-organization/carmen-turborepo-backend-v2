meta {
  name: 01 - List Product Sub Category
  type: http
  seq: 1
}

docs {
  ## List Product Sub Categories
  แสดงรายการหมวดหมู่ย่อยสินค้าทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Returns all product sub-categories configured for the business unit.
}

get {
  url: {{host}}/api/config/{{bu_code}}/products/sub-category
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
