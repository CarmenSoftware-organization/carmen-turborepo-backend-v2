meta {
  name: 04 - Update User
  type: http
  seq: 4
}

docs {
  ## Update User
  อัปเดตข้อมูลผู้ใช้ที่มีอยู่

  Update an existing user's profile information.
}

put {
  url: {{host}}/api/user/:user_id
  body: json
  auth: bearer
}

params:path {
  user_id: {{user_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "",
    "email": ""
  }
}
