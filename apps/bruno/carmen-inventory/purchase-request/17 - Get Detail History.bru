meta {
  name: 17 - Get Detail History
  type: http
  seq: 17
}

get {
  url: {{host}}/api/{{bu_code}}/purchase-request/detail/:detail_id/history
  body: none
  auth: bearer
}

params:path {
  detail_id: {{pr_detail_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
