meta {
  name: 07 - Save Spot Check
  type: http
  seq: 7
}

patch {
  url: {{host}}/api/{{bu_code}}/spot-check/:id/save
  body: json
  auth: bearer
}

params:path {
  id: {{spot_check_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "items": [
      {
        "id": "{{spot_check_detail_id}}",
        "actual_qty": 42.5
      }
    ]
  }
}

vars:pre-request {
  spot_check_id:
  spot_check_detail_id:
}
