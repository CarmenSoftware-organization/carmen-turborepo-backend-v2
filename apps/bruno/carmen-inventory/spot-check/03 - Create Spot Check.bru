meta {
  name: 03 - Create Spot Check
  type: http
  seq: 3
}

post {
  url: {{host}}/api/{{bu_code}}/spot-check
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "location_id": "<location_uuid>",
    "method": "random",
    "items": 10,
    "description": "Weekly spot check for dry goods storage",
    "note": "Focus on high-value items"
  }
}
