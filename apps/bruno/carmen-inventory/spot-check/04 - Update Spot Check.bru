meta {
  name: 04 - Update Spot Check
  type: http
  seq: 4
}

patch {
  url: {{host}}/api/{{bu_code}}/spot-check/:id
  body: json
  auth: bearer
}

params:path {
  id: {{spot_check_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "description": "Updated spot check description",
    "note": "Updated note - check expiry dates"
  }
}
