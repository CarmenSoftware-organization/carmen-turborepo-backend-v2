meta {
  name: 03 - Create Period
  type: http
  seq: 3
}

post {
  url: {{host}}/api/{{bu_code}}/period
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "fiscal_year": 2026,
    "fiscal_month": 4,
    "start_at": "2026-04-01T00:00:00.000Z",
    "end_at": "2026-04-30T23:59:59.000Z",
    "status": "open"
  }
}
