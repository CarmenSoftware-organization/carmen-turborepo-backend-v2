meta {
  name: 03 - Create Period
  type: http
  seq: 3
}

post {
  url: {{host}}/api/{{bu_code}}/period
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "period": "2602", // no string
    "fiscal_year": 26, // 2026
    "fiscal_month": 2, // febu
    "start_at": "2026-02-01T00:00:00.761Z",
    "end_at": "2026-02-28T00:00:00.761Z",
    "status": "open" // closed, locked
  }
}
