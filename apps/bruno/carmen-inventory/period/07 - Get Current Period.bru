meta {
  name: 07 - Get Current Period
  type: http
  seq: 7
}

docs {
  ## Get Current Period
  ดึงข้อมูลรอบบัญชีปัจจุบัน (สถานะเปิดหรือล็อค)

  Retrieve the current fiscal/accounting period (status open or locked).
}

get {
  url: {{host}}/api/{{bu_code}}/period/current
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
