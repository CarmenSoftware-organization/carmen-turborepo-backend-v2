meta {
  name: 05 - Generate Report (PDF)
  type: http
  seq: 5
}

docs {
  ## Generate Report (PDF)
  สร้างรายงานในรูปแบบ PDF

  Generate a report in PDF format.
}

post {
  url: {{host}}/api/{{bu_code}}/report/generate
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "report_type": "inventory_summary",
    "format": "pdf",
    "filters": {},
    "options": {}
  }
}
