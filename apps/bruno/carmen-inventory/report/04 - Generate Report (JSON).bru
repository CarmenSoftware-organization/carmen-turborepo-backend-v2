meta {
  name: 04 - Generate Report (JSON)
  type: http
  seq: 4
}

post {
  url: {{host}}/api/{{bu_code}}/report/generate
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "report_type": "inventory_summary",
    "format": "json",
    "filters": {},
    "options": {}
  }
}
