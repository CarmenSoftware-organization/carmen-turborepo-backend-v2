meta {
  name: 02 - Get Location
  type: http
  seq: 3
}

docs {
  ## Get Location
  ดึงข้อมูลสถานที่/คลังสินค้ารายการเดียวตาม ID

  Retrieves a single location/warehouse record by its unique identifier.
}

get {
  url: {{host}}/api/{{bu_code}}/locations/:id
  body: none
  auth: bearer
}

params:path {
  id: {{location_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
