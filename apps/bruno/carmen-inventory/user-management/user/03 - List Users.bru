meta {
  name: 03 - List Users
  type: http
  seq: 3
}

docs {
  ## List Users
  แสดงรายการผู้ใช้ทั้งหมดในหน่วยธุรกิจปัจจุบันพร้อมการแบ่งหน้าและค้นหา

  Retrieve all users in the current business unit with pagination and search support.
}

get {
  url: {{host}}/api/{{bu_code}}/users
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
