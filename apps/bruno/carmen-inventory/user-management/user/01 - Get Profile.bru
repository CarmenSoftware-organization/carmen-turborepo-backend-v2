meta {
  name: 01 - Get Profile
  type: http
  seq: 1
}

docs {
  ## Get Profile
  ดึงข้อมูลโปรไฟล์ของผู้ใช้ที่เข้าสู่ระบบ

  Retrieve the authenticated user's profile information.
}

get {
  url: {{host}}/api/user/profile
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
