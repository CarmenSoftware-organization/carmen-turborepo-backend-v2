meta {
  name: 02 - Get Permission
  type: http
  seq: 2
}

docs {
  ## Get Permission
  ดึงข้อมูลสิทธิ์การใช้งานของผู้ใช้ที่เข้าสู่ระบบ

  Retrieve the authenticated user's permission set.
}

get {
  url: {{host}}/api/user/permission
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
