meta {
  name: 03 - Create Physical Count
  type: http
  seq: 3
}

post {
  url: {{host}}/api/{{bu_code}}/physical-count
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "period_id": "{{period_id}}",
    "location_id": "{{location_id}}",
    "description": "Physical Count Test"
  }
}

vars:pre-request {
  period_id: 4b589f8b-9fa7-4e62-a5b5-e6bf45c4f9bb
  location_id: 47414c16-9d52-4b16-8428-4a4c4e89986e
