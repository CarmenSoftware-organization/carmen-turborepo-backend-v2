meta {
  name: 02 - Get Physical Count Detail
  type: http
  seq: 2
}

get {
  url: {{host}}/api/{{bu_code}}/physical-count/:id/details/:detail_id
  body: none
  auth: bearer
}

params:path {
  id: {{physical_count_id}}
  detail_id: {{physical_count_detail_id}}
}

auth:bearer {
  token: {{access_token}}
}
