meta {
  name: 07 - Save Physical Count
  type: http
  seq: 7
}

patch {
  url: {{host}}/api/{{bu_code}}/physical-count/:id/save
  body: json
  auth: bearer
}

params:path {
  id: {{physical_count_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "items": [
      {
        "id": "{{physical_count_detail_id}}",
        "actual_qty": 10
      }
    ]
  }
}

vars:pre-request {
  physical_count_id:
  physical_count_detail_id:
}
