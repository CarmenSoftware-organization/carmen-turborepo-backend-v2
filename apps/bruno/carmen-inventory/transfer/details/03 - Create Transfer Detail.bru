meta {
  name: 03 - Create Transfer Detail
  type: http
  seq: 3
}

post {
  url: {{host}}/api/{{bu_code}}/transfer/:id/details
  body: json
  auth: bearer
}

params:path {
  id: {{transfer_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "product_id": "",
    "product_name": "",
    "qty": 3,
    "cost_per_unit": 100,
    "total_cost": 300,
    "description": "",
    "note": ""
  }
}
