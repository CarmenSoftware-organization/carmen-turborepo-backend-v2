meta {
  name: 04 - Get Pending PR by ID
  type: http
  seq: 4
}

get {
  url: {{host}}/api/my-pending/purchase-request/:bu_code/:id
  body: none
  auth: bearer
}

params:path {
  bu_code: {{bu_code}}
  id: {{pr_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
