meta {
  name: 08 - Approve Pending PR
  type: http
  seq: 8
}

patch {
  url: {{host}}/api/my-pending/purchase-request/:bu_code/:id/approve
  body: json
  auth: bearer
}

params:path {
  bu_code: {{bu_code}}
  id: {{pr_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {}
}
