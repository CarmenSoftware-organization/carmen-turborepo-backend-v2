meta {
  name: 01 - List Price List Template
  type: http
  seq: 1
}

docs {
  ## List Price List Templates
  แสดงรายการแม่แบบรายการราคาทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Lists all available price list templates for the business unit with pagination and search support.
}

get {
  url: {{host}}/api/{{bu_code}}/price-list-template
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
