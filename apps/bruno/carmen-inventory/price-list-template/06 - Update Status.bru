meta {
  name: 06 - Update Status
  type: http
  seq: 7
}

patch {
  url: {{host}}/api/{{bu_code}}/price-list-template/:id/status
  body: json
  auth: bearer
}

params:path {
  id: {{price_list_template_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "is_active": true
  }
}
