meta {
  name: 03 - List Inventory Transaction (Stock-Out)
  type: http
  seq: 3
}

docs {
  ## List Inventory Transactions (Stock-Out only)
  ดึงรายการเคลื่อนไหวสินค้าคงคลังเฉพาะประเภท Stock-Out

  Lists inventory transactions filtered by stock_out doc type.


  ### Sample Response
  ```json
  {
    "data": [
      {
        "id": "uuid",
        "transaction_type": "stock_in",
        "transaction_date": "2026-03-27T00:00:00.000Z",
        "product_id": "uuid",
        "product_name": "Product Name",
        "location_id": "uuid",
        "location_name": "Main Store",
        "qty": 100,
        "reference_no": "SI-2026-0001",
        "created_at": "2026-03-27T00:00:00.000Z"
      }
    ],
    "paginate": {
      "total": 100,
      "page": 1,
      "perpage": 10,
      "pages": 10
    },
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

get {
  url: {{host}}/api/{{bu_code}}/inventory-transaction?filter=inventory_doc_type:stock_out
  body: none
  auth: bearer
}

params:query {
  filter: inventory_doc_type:stock_out
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
