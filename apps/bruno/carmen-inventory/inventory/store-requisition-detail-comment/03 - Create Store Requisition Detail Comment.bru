meta {
  name: 03 - Create Store Requisition Detail Comment
  type: http
  seq: 3
}

docs {
  ## Create Store Requisition Detail Comment
  สร้างความคิดเห็นใหม่สำหรับรายละเอียดใบเบิกสินค้าร้านค้า

  Posts a new comment on a store-requisition-detail.

  ### Sample Body
  ```json
  {
    "store_requisition_detail_id": "{{test_id}}",
    "message": ""
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 201,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

post {
  url: {{host}}/api/{{bu_code}}/store-requisition-detail-comment
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "store_requisition_detail_id": "{{test_id}}",
    "message": ""
  }
}
