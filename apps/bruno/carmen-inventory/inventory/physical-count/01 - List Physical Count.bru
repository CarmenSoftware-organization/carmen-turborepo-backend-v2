meta {
  name: List physical-count
  type: http
  seq: 1
}

get {
  url: {{host}}/api/{{bu_code}}/physical-count
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
