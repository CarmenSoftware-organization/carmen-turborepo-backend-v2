meta {
  name: Find all by count stock id count-stock-comment
  type: http
  seq: 1
}

get {
  url: {{host}}/api/{{bu_code}}/count-stock/:count_stock_id/comments
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

query {
  ~version: 
}

docs {
  ## List Count Stock Comments
  แสดงความคิดเห็นทั้งหมดของการนับสต็อก

  Retrieves all comments for a count-stock.

  ### Path Parameters
  - `count_stock_id` — Count Stock ID


  ### Sample Response
  ```json
  {
    "data": [
      {
        "id": "uuid",
        "message": "comment text"
      }
    ],
    "paginate": {
      "total": 100,
      "page": 1,
      "perpage": 10,
      "pages": 10
    },
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

params:path {
  count_stock_id: {{test_id}}
}
