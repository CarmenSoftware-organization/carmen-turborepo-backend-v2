  url: {{host}}/api/{{bu_code}}/inventory-adjustment/:id?type=stock-in
  body: none
  auth: bearer
}

params:query {
  type: stock-in
}

params:path {
  id: {{inventory_adjustment_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
