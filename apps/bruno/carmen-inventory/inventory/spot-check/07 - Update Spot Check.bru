}

query {
  ~version: 
}

body:json {
  {
    "description": "",
    "note": "",
    "info": null,
    "dimension": null
  }
}

vars:pre-request {
  spot_check_id:
}

docs {
  ## Update Spot Check
  แก้ไขรายการตรวจสอบสินค้าเฉพาะจุดก่อนการส่ง เช่น อัปเดตสถานที่หรือปรับสินค้าที่ต้องการตรวจสอบ

  Modifies a spot check record before submission, such as updating the location or adjusting which products are included in the verification.

  ### Path Parameters
  - `bu_code` — Business Unit Code / รหัสหน่วยธุรกิจ
  - `id` — Spot Check ID / รหัสการตรวจสอบสินค้าเฉพาะจุด


  ### Sample Body
  ```json
  {
    "description": "Updated spot check description",
    "note": "Updated note - check expiry dates"
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid",
      "spot_check_no": "SC-2026-0001",
      "doc_status": "draft"
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

params:path {
  id: {{spot_check_id}}
}
