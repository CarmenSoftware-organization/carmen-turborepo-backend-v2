meta {
  name: Delete detail spot-check
  type: http
  seq: 14
}

delete {
  url: {{host}}/api/{{bu_code}}/spot-check/:id/details/:detail_id
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
