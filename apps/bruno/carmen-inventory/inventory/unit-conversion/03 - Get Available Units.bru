}

query {
  ~version: 
}

vars:pre-request {
  product_id: 37a9ac81-b0d8-4f77-a727-41ad5ae9144c
}

docs {
  ## Get Available Units
  ดึงการแปลงหน่วยทั้งหมดที่ใช้ได้สำหรับสินค้าตาม Product ID
  
  Retrieves all configured unit conversions available for a specific product.
  
  
  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid",
      "name": "Item Name"
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

params:query {
  ~version: 
}

params:path {
  productId: {{product_id}}
}
