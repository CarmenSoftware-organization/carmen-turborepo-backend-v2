meta {
  name: 01 - Get Order Units
  type: http
  seq: 1
}

docs {
  ## Get Order Units
  ดึงหน่วยสั่งซื้อที่ใช้ได้สำหรับสินค้าตาม Product ID

  Retrieves available ordering units for a specific product.
}

get {
  url: {{host}}/api/{{bu_code}}/unit/order/product/:productId
  body: none
  auth: bearer
}

params:path {
  productId: {{product_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
