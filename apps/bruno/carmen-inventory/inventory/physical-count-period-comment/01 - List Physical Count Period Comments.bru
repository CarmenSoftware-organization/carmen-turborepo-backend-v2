  type: http
  seq: 1
}

get {
  url: {{host}}/api/{{bu_code}}/physical-count-period/:physical_count_period_id/comments
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

query {
  ~version: 
}

docs {
  ## List Physical Count Period Comments
  แสดงความคิดเห็นทั้งหมดของรอบการนับสินค้าจริง

  Retrieves all comments for a physical-count-period.

  ### Path Parameters
  - `physical_count_period_id` — Physical Count Period ID


  ### Sample Response
  ```json
  {
    "data": [
      {
        "id": "uuid",
        "message": "comment text"
      }
    ],
    "paginate": {
      "total": 100,
      "page": 1,
      "perpage": 10,
      "pages": 10
    },
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

params:path {
  physical_count_period_id: {{test_id}}
}
