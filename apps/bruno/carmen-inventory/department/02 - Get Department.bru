meta {
  name: 02 - Get Department
  type: http
  seq: 2
}

docs {
  ## Get Department
  ดึงข้อมูลแผนกรายการเดียวตาม ID

  Retrieves a single department record by its unique identifier.
}

get {
  url: {{host}}/api/{{bu_code}}/department/:id
  body: none
  auth: bearer
}

params:path {
  id: {{department_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
