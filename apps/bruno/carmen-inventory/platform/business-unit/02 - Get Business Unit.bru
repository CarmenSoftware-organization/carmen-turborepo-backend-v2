docs {
  ## Get Business Unit
  ดึงข้อมูลหน่วยธุรกิจรายการเดียวตาม ID

  Retrieve a single business unit by its ID.
}

get {
  url: {{host}}/api-system/business-unit/:id
  body: none
  auth: bearer
}

params:path {
  id:
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
