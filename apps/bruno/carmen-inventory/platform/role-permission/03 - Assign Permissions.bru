meta {
  name: 03 - Assign Permissions
  type: http
  seq: 3
}

docs {
  ## Assign Permissions
  กำหนดสิทธิ์ตามบทบาทหลายรายการให้บทบาทพร้อมกัน

  Assign multiple permissions to a role in bulk.


  ### Sample Body
  ```json
  {
    "role_id": "",
    "permission_ids": []
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

post {
  url: {{host}}/api-system/role-permission/assign-permissions
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "role_id": "",
    "permission_ids": []
  }
}
