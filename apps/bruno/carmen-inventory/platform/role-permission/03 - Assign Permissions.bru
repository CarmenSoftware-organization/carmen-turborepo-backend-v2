meta {
  name: 03 - Assign Permissions
  type: http
  seq: 3
}

docs {
  ## Assign Permissions
  กำหนดสิทธิ์ตามบทบาทหลายรายการให้บทบาทพร้อมกัน

  Assign multiple permissions to a role in bulk.
}

post {
  url: {{host}}/api-system/role-permission/assign-permissions
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "role_id": "",
    "permission_ids": []
  }
}
