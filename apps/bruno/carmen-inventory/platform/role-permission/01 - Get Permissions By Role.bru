meta {
  name: 01 - Get Permissions By Role
  type: http
  seq: 1
}

docs {
  ## Get Permissions By Role
  ดึงรายการสิทธิ์การใช้งานทั้งหมดที่กำหนดให้บทบาทที่ระบุ

  Retrieve all permissions assigned to a specific role.
}

get {
  url: {{host}}/api-system/role-permission/role/:roleId/permissions
  body: none
  auth: bearer
}

params:path {
  roleId:
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
