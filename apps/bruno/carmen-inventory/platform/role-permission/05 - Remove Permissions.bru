meta {
  name: 05 - Remove Permissions
  type: http
  seq: 5
}

docs {
  ## Remove Permissions
  ถอนสิทธิ์ตามบทบาทหลายรายการจากบทบาทพร้อมกัน

  Remove multiple permissions from a role in bulk.
}

delete {
  url: {{host}}/api-system/role-permission/remove-permissions
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "role_id": "",
    "permission_ids": []
  }
}
