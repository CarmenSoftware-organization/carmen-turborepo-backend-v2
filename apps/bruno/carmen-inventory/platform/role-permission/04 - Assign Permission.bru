meta {
  name: 04 - Assign Permission
  type: http
  seq: 4
}

docs {
  ## Assign Permission
  กำหนดสิทธิ์ตามบทบาทรายการเดียวให้บทบาท

  Assign a single permission to a role.
}

post {
  url: {{host}}/api-system/role-permission/assign-permission
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "role_id": "",
    "permission_id": ""
  }
}
