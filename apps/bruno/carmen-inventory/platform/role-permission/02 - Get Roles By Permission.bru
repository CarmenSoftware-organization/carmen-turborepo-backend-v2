meta {
  name: 02 - Get Roles By Permission
  type: http
  seq: 2
}

docs {
  ## Get Roles By Permission
  ดึงรายการบทบาททั้งหมดที่มีสิทธิ์การใช้งานที่ระบุ

  Retrieve all roles that have a specific permission.
}

get {
  url: {{host}}/api-system/role-permission/permission/:permissionId/roles
  body: none
  auth: bearer
}

params:path {
  permissionId:
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
