meta {
  name: 03 - Create User Business Unit
  type: http
  seq: 3
}

docs {
  ## Create User Business Unit
  สร้างหน่วยธุรกิจของผู้ใช้ใหม่

  Create a new user-business unit mapping.
}

post {
  url: {{host}}/api-system/user/business-unit
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "user_id": "",
    "business_unit_id": "",
    "role": "member",
    "is_default": false,
    "is_active": true
  }
}
