meta {
  name: List platform_user-business-unit
  type: http
  seq: 1
}

get {
  url: {{host}}/api-system/user/business-unit
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
