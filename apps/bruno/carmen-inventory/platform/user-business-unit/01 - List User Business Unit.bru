meta {
  name: 01 - List User Business Unit
  type: http
  seq: 1
}

docs {
  ## List User Business Unit
  แสดงรายการหน่วยธุรกิจของผู้ใช้ทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieve all user-business unit mappings with pagination and search support.
}

get {
  url: {{host}}/api-system/user/business-unit
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
