}

docs {
  ## Update Permission
  อัปเดตข้อมูลสิทธิ์การใช้งานที่มีอยู่

  Update an existing permission.
}

put {
  url: {{host}}/api-system/permission/:id
  body: json
  auth: bearer
}

params:path {
  id:
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "Permission 01 Updated",
    "is_active": true
  }
}
