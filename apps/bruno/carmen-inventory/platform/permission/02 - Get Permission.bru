}

docs {
  ## Get Permission
  ดึงข้อมูลสิทธิ์การใช้งานรายการเดียวตาม ID

  Retrieve a single permission by its ID.
}

get {
  url: {{host}}/api-system/permission/:id
  body: none
  auth: bearer
}

params:path {
  id:
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
