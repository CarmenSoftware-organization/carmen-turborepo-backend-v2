docs {
  ## Get User
  ดึงข้อมูลผู้ใช้รายการเดียวตาม ID

  Retrieve a single user by their ID.
}

get {
  url: {{host}}/api-system/user/:id
  body: none
  auth: bearer
}

params:path {
  id:
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
