meta {
  name: 01 - List User Cluster
  type: http
  seq: 1
}

docs {
  ## List User Cluster
  แสดงรายการคลัสเตอร์ของผู้ใช้ทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieve all user-cluster mappings with pagination and search support.
}

get {
  url: {{host}}/api-system/user/cluster
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
