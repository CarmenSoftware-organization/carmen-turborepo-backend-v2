meta {
  name: 01 - List Documents
  type: http
  seq: 1
}

docs {
  ## List Documents
  แสดงรายการเอกสารทั้งหมดพร้อมการแบ่งหน้าและค้นหา

  Retrieve all documents with pagination and search support.
}

get {
  url: {{host}}/api/{{bu_code}}/documents
  body: none
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
