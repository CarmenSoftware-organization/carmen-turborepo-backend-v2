meta {
  name: 05 - Delete Document
  type: http
  seq: 5
}

docs {
  ## Delete Document
  ลบเอกสารตาม file token

  Delete a document by its file token.
}

delete {
  url: {{host}}/api/{{bu_code}}/documents/:filetoken
  body: none
  auth: bearer
}

params:path {
  filetoken: {{filetoken}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
