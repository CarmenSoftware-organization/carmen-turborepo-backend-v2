meta {
  name: 01 - List Request For Pricing Detail Comments
  type: http
  seq: 1
}

docs {
  ## List Request For Pricing Detail Comments
  แสดงความคิดเห็นทั้งหมดของรายละเอียดใบขอราคา

  Retrieves all comments for a request-for-pricing-detail.

  ### Path Parameters
  - `request_for_pricing_detail_id` — Request For Pricing Detail ID


  ### Sample Response
  ```json
  {
    "data": [
      {
        "id": "uuid",
        "message": "comment text"
      }
    ],
    "paginate": {
      "total": 100,
      "page": 1,
      "perpage": 10,
      "pages": 10
    },
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

get {
  url: {{host}}/api/{{bu_code}}/request-for-pricing-detail/:request_for_pricing_detail_id/comment
  body: none
  auth: bearer
}

params:path {
  request_for_pricing_detail_id: {{test_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
