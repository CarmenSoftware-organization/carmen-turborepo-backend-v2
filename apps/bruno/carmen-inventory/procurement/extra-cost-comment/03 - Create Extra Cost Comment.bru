meta {
  name: 03 - Create Extra Cost Comment
  type: http
  seq: 3
}

docs {
  ## Create Extra Cost Comment
  สร้างความคิดเห็นใหม่สำหรับค่าใช้จ่ายเพิ่มเติม

  Posts a new comment on a extra-cost.

  ### Sample Body
  ```json
  {
    "extra_cost_id": "{{test_id}}",
    "message": ""
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "id": "uuid"
    },
    "paginate": null,
    "status": 201,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

post {
  url: {{host}}/api/{{bu_code}}/extra-cost-comment
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "extra_cost_id": "{{test_id}}",
    "message": ""
  }
}
