meta {
  name: 01 - List Credit Note Detail Comments
  type: http
  seq: 1
}

docs {
  ## List Credit Note Detail Comments
  แสดงความคิดเห็นทั้งหมดของรายละเอียดใบลดหนี้

  Retrieves all comments for a credit-note-detail.

  ### Path Parameters
  - `credit_note_detail_id` — Credit Note Detail ID


  ### Sample Response
  ```json
  {
    "data": [
      {
        "id": "uuid",
        "message": "comment text"
      }
    ],
    "paginate": {
      "total": 100,
      "page": 1,
      "perpage": 10,
      "pages": 10
    },
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-03-27T00:00:00.000Z"
  }
  ```
}

get {
  url: {{host}}/api/{{bu_code}}/credit-note-detail/:credit_note_detail_id/comments
  body: none
  auth: bearer
}

params:path {
  credit_note_detail_id: {{test_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
