meta {
  name: Approve purchase-order
  type: http
  seq: 15
}

patch {
  url: {{host}}/api/{{bu_code}}/purchase-order/:id/approve
  body: json
  auth: bearer
}

headers {
  x-app-id: {{x_app_id}}
  Content-Type: application/json
}

