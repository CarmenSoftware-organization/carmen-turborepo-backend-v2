          "order_unit_name": "kg",
          "order_qty": 80,
          "base_unit_id": "<unit_uuid>",
          "base_unit_name": "kg",
          "base_qty": 80,
          "price": 45,
          "sub_total_price": 3600,
          "net_amount": 3420,
          "total_price": 3659.4,
          "tax_rate": 7,
          "tax_amount": 239.4,
          "discount_rate": 5,
          "discount_amount": 180,
