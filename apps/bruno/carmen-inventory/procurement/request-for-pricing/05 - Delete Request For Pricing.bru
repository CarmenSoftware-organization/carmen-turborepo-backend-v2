docs {
  ## Delete Request For Pricing
  ลบใบขอราคาตาม ID

  Delete a request for pricing by its ID.
}

delete {
  url: {{host}}/api/{{bu_code}}/request-for-pricing/:id
  body: none
  auth: bearer
}

params:path {
  id: {{rfp_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
