meta {
  name: 07 - Forgot Password
  type: http
  seq: 7
}

docs {
  ## Forgot Password
  ลืมรหัสผ่าน - ส่งอีเมลรีเซ็ตรหัสผ่านพร้อมโทเค็นที่ปลอดภัยไปยังอีเมลที่ลงทะเบียนไว้

  Initiates the password recovery flow by sending a password reset email with a secure token link to the registered email address.
}

post {
  url: {{host}}/api/auth/forgot-password
  body: json
  auth: none
}

headers {
  x-app-id: {{x_app_id}}
}

body:json {
  {
    "email": ""
  }
}
