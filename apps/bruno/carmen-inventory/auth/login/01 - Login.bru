meta {
  name: 01 - Login
  type: http
  seq: 1
}

docs {
  ## Login
  เข้าสู่ระบบด้วยอีเมลหรือชื่อผู้ใช้และรหัสผ่านผ่าน Keycloak เพื่อรับ access_token และ refresh_token สำหรับเรียก API ทุกโมดูล ERP

  Authenticates a user against Keycloak using email or username with password credentials, returning JWT access and refresh tokens for subsequent API requests across all ERP modules.

  ### Headers
  | Name | Required | Description |
  |------|----------|-------------|
  | `x-app-id` | Yes | `{{x_app_id}}` |

  ### Permissions
  Public — no auth required

  ### Sample Body
  ```json
  {
    "email": "john.doe@carmensoftware.com",
    "password": "P@ssw0rd!23"
  }
  ```

  ### Sample Response
  ```json
  {
    "data": {
      "access_token": "eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJhYmMxMjMifQ.<truncated>",
      "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJ4eXo5ODcifQ.<truncated>",
      "expires_in": 300,
      "refresh_expires_in": 1800,
      "token_type": "Bearer"
    },
    "paginate": null,
    "status": 200,
    "success": true,
    "message": "Success",
    "timestamp": "2026-04-29T08:30:00.000Z"
  }
  ```

  ### Error Responses
  | Status | When |
  |--------|------|
  | 401 | Invalid credentials (wrong email/password) |
}

post {
  url: {{host}}/api/auth/login
  body: json
  auth: none
}

headers {
  x-app-id: {{x_app_id}}
}

body:json {
  {
    "email": "test@test.com",
    "password": "123456"
  }
}

script:post-response {
  if (res.body.data) {
    bru.setEnvVar('access_token', res.body.data.access_token);
    bru.setEnvVar('refresh_token', res.body.data.refresh_token);
  } else {
    bru.setEnvVar('access_token', '');
    bru.setEnvVar('refresh_token', '');
  }
}
