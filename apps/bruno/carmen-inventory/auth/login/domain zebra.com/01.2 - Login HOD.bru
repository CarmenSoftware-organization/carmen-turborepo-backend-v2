meta {
  name: 01.2 - Login HOD
  type: http
  seq: 2
}

docs {
  ## Login HOD (zebra.com)
  เข้าสู่ระบบด้วยบทบาทหัวหน้าแผนก (HOD) สำหรับโดเมน zebra.com

  Login as a Head of Department (HOD) role user for the zebra.com domain.
}

post {
  url: {{host}}/api/auth/login
  body: json
  auth: none
}

headers {
  x-app-id: {{x_app_id}}
}

body:json {
  {
    "email": "HOD@zebra.com",
    "password": "12345678"
  }
}

script:post-response {
  if (res.body.data) {
    bru.setEnvVar('access_token', res.body.data.access_token);
    bru.setEnvVar('refresh_token', res.body.data.refresh_token);
  } else {
    bru.setEnvVar('access_token', '');
    bru.setEnvVar('refresh_token', '');
  }
}
