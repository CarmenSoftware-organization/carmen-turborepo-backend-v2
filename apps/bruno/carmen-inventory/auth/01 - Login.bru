meta {
  name: 01 - Login
  type: http
  seq: 1
}

post {
  url: {{host}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "",
    "password": ""
  }
}

script:post-response {
  bru.setEnvVar('access_token', res.body.access_token);
  bru.setEnvVar('refresh_token', res.body.refresh_token);
}
