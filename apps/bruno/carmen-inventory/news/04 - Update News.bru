meta {
  name: 04 - Update News
  type: http
  seq: 4
}

docs {
  ## Update News
  อัปเดตข้อมูลข่าวสารที่มีอยู่

  Update an existing news article.
}

put {
  url: {{host}}/api/news/:id
  body: json
  auth: bearer
}

params:path {
  id: {{news_id}}
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "title": "",
    "content": "",
    "is_active": true
  }
}
