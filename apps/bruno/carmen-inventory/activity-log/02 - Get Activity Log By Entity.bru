meta {
  name: 02 - Get Activity Log By Entity
  type: http
  seq: 2
}

docs {
  ## Get Activity Log By Entity
  ดึงรายการบันทึกกิจกรรมตามประเภทเอกสาร

  Retrieve activity logs filtered by entity type.
}

get {
  url: {{host}}/api/{{bu_code}}/activity-log/entity/:entity_type
  body: none
  auth: bearer
}

params:path {
  entity_type: purchase_request
}

headers {
  x-app-id: {{x_app_id}}
}

auth:bearer {
  token: {{access_token}}
}
