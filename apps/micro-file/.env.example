# Prisma OpenSSL fix for Ubuntu
PRISMA_CLIENT_ENGINE_TYPE=library

# Application Name
APP_NAME=micro-file
NODE_ENV=development

## PORT

GATEWAY_SERVICE_HOST=localhost
GATEWAY_SERVICE_HTTP_PORT=4000
GATEWAY_SERVICE_HTTPS_PORT=4001

BUSINESS_SERVICE_HOST=localhost
BUSINESS_SERVICE_HTTP_PORT=5020
BUSINESS_SERVICE_HTTPS_PORT=6020

CLUSTER_SERVICE_HOST=localhost
CLUSTER_SERVICE_HTTP_PORT=5014
CLUSTER_SERVICE_HTTPS_PORT=6014

CRONJOB_SERVICE_HOST=localhost
CRONJOB_SERVICE_HTTP_PORT=5012
CRONJOB_SERVICE_HTTPS_PORT=6012

FILE_SERVICE_HOST=localhost
FILE_SERVICE_HTTP_PORT=5007
FILE_SERVICE_HTTPS_PORT=6007

KEYCLOAK_API_SERVICE_HOST=localhost
KEYCLOAK_API_SERVICE_HTTP_PORT=5013
KEYCLOAK_API_SERVICE_HTTPS_PORT=6013

NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_HTTP_PORT=5006
NOTIFICATION_SERVICE_HTTPS_PORT=6006

REPORT_SERVICE_HOST=localhost
REPORT_SERVICE_HTTP_PORT=5015
REPORT_SERVICE_HTTPS_PORT=6015
REPORT_SERVICE_GRPC_PORT=4015

REPORT_RENDER_HOST=localhost
REPORT_RENDER_HTTP_PORT=8001
REPORT_RENDER_HTTPS_PORT=8002

# MinIO Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=your-bucket-name

LOG_LEVEL=info
