# Prisma OpenSSL fix for Ubuntu
PRISMA_CLIENT_ENGINE_TYPE=library
# micro-file service
FILE_SERVICE_HOST=0.0.0.0
FILE_SERVICE_PORT=5007
FILE_SERVICE_HTTP_PORT=6007

LOKI_HOST=dev.blueledgers.com
LOKI_PORT=3998
LOKI_PROTOCOL=http
LOKI_USERNAME=
LOKI_PASSWORD=
APP_NAME=micro-file
NODE_ENV=development

MINIO_ENDPOINT=http://dev.blueledgers.com:3990
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=carmen