# Prisma OpenSSL fix for Ubuntu
PRISMA_CLIENT_ENGINE_TYPE=library
# micro-cluster service
CLUSTER_SERVICE_HOST=0.0.0.0
CLUSTER_SERVICE_PORT=5014
CLUSTER_SERVICE_HTTP_PORT=6014

# Database
SYSTEM_DATABASE_URL="postgresql://user:password@localhost:5432/postgres?schema=CARMEN_SYSTEM"
SYSTEM_DIRECT_URL="postgresql://user:password@localhost:5432/postgres?schema=CARMEN_SYSTEM"

# JWT configuration
SUPABASE_JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
JWT_INVITE_EXPIRES_IN=1d

# Inter-service communication (external services)
KEYCLOAK_API_SERVICE_HOST=127.0.0.1
KEYCLOAK_API_SERVICE_PORT=5013

# Logging (Loki)
LOKI_HOST=dev.blueledgers.com
LOKI_PORT=3998
LOKI_PROTOCOL=http
LOKI_USERNAME=
LOKI_PASSWORD=
APP_NAME=micro-cluster
NODE_ENV=development
LOG_LEVEL=info

# Sentry
SENTRY_DSN=
