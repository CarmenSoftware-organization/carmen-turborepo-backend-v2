# Cluster service
CLUSTER_SERVICE_HOST=localhost
CLUSTER_SERVICE_PORT=5014
CLUSTER_SERVICE_HTTP_PORT=6014

# Database
SYSTEM_DATABASE_URL=postgresql://user:password@localhost:5432/carmen_platform?schema=public
SYSTEM_DIRECT_URL=postgresql://user:password@localhost:5432/carmen_platform?schema=public

# JWT
SUPABASE_JWT_SECRET=your-jwt-secret

# External services
KEYCLOAK_API_SERVICE_HOST=localhost
KEYCLOAK_API_SERVICE_PORT=5013

# Loki logging (optional)
LOKI_HOST=localhost
LOKI_PORT=3100
LOKI_PROTOCOL=http
APP_NAME=micro-cluster

# Sentry (optional)
SENTRY_DSN=
